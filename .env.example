# Database (app connects to the postgres service inside Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=telegramrag
DB_PASSWORD=change_me
DB_NAME=telegramrag

# RAG
EMBEDDING_MODEL=sentence-transformers/clip-ViT-B-32
EMBEDDING_N_DIM=512
RAG_STRATEGY=hyde
TOP_K=5
LLM_MODEL=ollama/gemma4

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_SESSION_NAME=telegramrag

# Docker / runtime (used by docker-compose and the app container CMD)
APP_PORT=8000
